{
  "schema_version": 1,
  "project_id": "wevito",
  "display_name": "Wevito",
  "root_path": "C:/path/to/wevito",
  "runtime_sprite_root": "sprites_runtime",
  "authored_sprite_root": "sprites_authored_verified",
  "incoming_handoff_root": "incoming_sprites/gemini_handoff_motion",
  "artifact_root": "vnext/artifacts",
  "review_data_path": ".sprite-workflow/reviews.json",
  "request_data_path": ".sprite-workflow/requests.json",
  "candidate_data_path": ".sprite-workflow/candidates.json",
  "default_ai_provider_id": "gemini-browser",
  "ai_providers": [
    {
      "provider_id": "gemini-browser",
      "display_name": "Gemini Browser Workflow",
      "provider_kind": "browser_chat",
      "execution_mode": "manual_browser",
      "supports_automation": false,
      "notes": "Keeps Gemini as a visible browser-driven provider adapter without baking Gemini assumptions into the shared request or candidate model."
    },
    {
      "provider_id": "local-hidden-tools",
      "display_name": "Local Hidden Workflow Tools",
      "provider_kind": "local_process",
      "execution_mode": "hidden_process",
      "supports_automation": true,
      "notes": "Runs local preparation, validation, and export actions as hidden child processes owned by the app."
    }
  ],
  "variant_axes": {
    "species": [
      "crow",
      "deer",
      "fox",
      "frog",
      "goose",
      "pigeon",
      "raccoon",
      "rat",
      "snake",
      "squirrel"
    ],
    "age": [
      "adult",
      "teen",
      "baby"
    ],
    "gender": [
      "female",
      "male"
    ],
    "color": [
      "red",
      "orange",
      "yellow",
      "blue",
      "indigo",
      "violet"
    ]
  },
  "families": {
    "locomotion": [
      {
        "sequence_id": "idle",
        "frame_count": 4
      },
      {
        "sequence_id": "walk",
        "frame_count": 6
      }
    ],
    "care": [
      {
        "sequence_id": "eat",
        "frame_count": 4
      },
      {
        "sequence_id": "sleep",
        "frame_count": 2
      }
    ],
    "expression": [
      {
        "sequence_id": "happy",
        "frame_count": 4
      },
      {
        "sequence_id": "sad",
        "frame_count": 2
      },
      {
        "sequence_id": "sick",
        "frame_count": 4
      },
      {
        "sequence_id": "bathe",
        "frame_count": 4
      }
    ]
  },
  "workflow_actions": [
    {
      "action_id": "export_authoring_packs",
      "display_name": "Export Authoring Packs",
      "description": "Rebuild the reusable authoring packs for the full roster before another generation or review wave.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\export_all_authoring_packs.py"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "prepare_locomotion_handoffs",
      "display_name": "Prepare Locomotion Handoffs",
      "description": "Refresh all locomotion Gemini handoff folders and editable boards from the latest project state.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\prepare_motion_gemini_handoff.py",
        "--family",
        "locomotion"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "prepare_care_handoffs",
      "display_name": "Prepare Care Handoffs",
      "description": "Refresh all care-family Gemini handoff folders and editable boards from the latest project state.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\prepare_motion_gemini_handoff.py",
        "--family",
        "care"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "prepare_expression_handoffs",
      "display_name": "Prepare Expression Handoffs",
      "description": "Refresh all expression Gemini handoff folders and editable boards from the latest project state.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\prepare_motion_gemini_handoff.py",
        "--family",
        "expression"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "rerender_previews",
      "display_name": "Rerender Previews",
      "description": "Render the latest authored-first preview sheets for species-level visual QA.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\render_runtime_sprite_previews.py",
        "--prefer-authored"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "refresh_coverage",
      "display_name": "Refresh Coverage",
      "description": "Recompute authored coverage and progress summaries from the on-disk sprite tree.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\report_authored_sprite_coverage.py"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "audit_sprite_contract",
      "display_name": "Audit Sprite Contract",
      "description": "Check the canonical source and runtime trees against the expected Wevito sprite contract.",
      "execution_mode": "hidden_process",
      "command": "python",
      "arguments": [
        ".\\tools\\audit_sprite_contract.py"
      ],
      "working_directory": "C:/path/to/wevito"
    },
    {
      "action_id": "gemini_generation_external",
      "display_name": "Gemini Generation",
      "description": "Continue generation in the existing logged-in Gemini window after the handoff packs are prepared. This stays external until the app has a safer direct integration.",
      "execution_mode": "manual_browser",
      "command": "Use the existing Gemini Chrome window",
      "arguments": [
        "Prepare handoffs in-app first",
        "Then continue generation manually in the current logged-in chat/window"
      ],
      "working_directory": "C:/path/to/wevito"
    }
  ]
}
