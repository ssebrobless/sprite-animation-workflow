<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpriteWorkflow.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="Root"
        x:Class="SpriteWorkflow.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1280"
        d:DesignHeight="860"
        Width="1280"
        Height="860"
        MinWidth="1080"
        MinHeight="760"
        KeyDown="OnWindowKeyDown"
        PointerReleased="OnWindowPointerReleased"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding AppTitle}"
        RequestedThemeVariant="Dark"
        Background="#11161D">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#11161D" />
        <SolidColorBrush x:Key="SidebarBgBrush" Color="#181F28" />
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#0B1117" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#1B2430" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#222D3A" />
        <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#2A3544" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#313E4F" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#3C4B5F" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E7EEF7" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9FB0C6" />
        <SolidColorBrush x:Key="AccentWarmBrush" Color="#6F5D46" />
        <SolidColorBrush x:Key="AccentCoolBrush" Color="#2F4F67" />
        <SolidColorBrush x:Key="AccentAlertBrush" Color="#6A4349" />
        <SolidColorBrush x:Key="AccentPillBrush" Color="#3A4657" />
        <SolidColorBrush x:Key="AccentAuditBrush" Color="#233546" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBgBrush}"
                Padding="24,18">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding AppTitle}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding Subtitle}"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="22">
            <StackPanel Spacing="16">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="22">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Selected Project"
                                   FontSize="16"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProjectName}"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedProjectSummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedProjectConfigPath}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*,*">
                    <Border Grid.Column="0"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,0,8,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Expected Variants"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding ExpectedVariantCount}"
                                       FontSize="26"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{DynamicResource AccentCoolBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="8,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Complete Variants"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding CompleteVariantCount}"
                                       FontSize="26"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{DynamicResource AccentAlertBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="8,0,0,0">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Incomplete Variants"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding IncompleteVariantCount}"
                                       FontSize="26"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Recent Activity"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="The app logs visible workflow steps here so review, editing, and automation work are easier to follow."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentPillBrush}"
                                    CornerRadius="999"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActivitySummary}"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                MaxHeight="180">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ActivityLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ActivityLogItemViewModel">
                                            <Grid ColumnDefinitions="Auto,Auto,*"
                                                  ColumnSpacing="10"
                                                  Margin="0,0,0,8">
                                                <TextBlock Text="{Binding TimestampLabel}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource AccentAuditBrush}"
                                                        CornerRadius="999"
                                                        Padding="8,2"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Area}" />
                                                </Border>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Message}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Visible Core Loop"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="New users should be able to watch the whole flow happen here: choose a row, preview it, paint it, save it, and replay it."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentPillBrush}"
                                    CornerRadius="999"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentWorkspaceLabel}"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding LoopGuideSummary}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="Auto,220,*"
                              ColumnSpacing="12">
                            <TextBlock Text="Control Mode"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ControlModeOptions}"
                                      SelectedItem="{Binding ControlMode}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ControlModeSummary}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="{Binding ControlModeHint}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*"
                              ColumnSpacing="10">
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="1 Review"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding ReviewStepSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Button Content="Go To Review"
                                            Command="{Binding OpenReviewWorkspaceCommand}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="▶"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Border Grid.Column="2"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="2 Animate"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding AnimateStepSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Button Content="Preview In Animate"
                                            Command="{Binding OpenAnimateWorkspaceCommand}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Grid.Column="3"
                                       Text="▶"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Border Grid.Column="4"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="3 Paint"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding PaintStepSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Button Content="Edit Current Frame"
                                            Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Grid.Column="5"
                                       Text="▶"
                                       FontSize="22"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Border Grid.Column="6"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="4 Save + Replay"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding SaveReplayStepSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Button Content="Save + Replay"
                                            Command="{Binding SaveAndReturnToAnimateCommand}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <TabControl Margin="0,6,0,0"
                            SelectedIndex="{Binding SelectedWorkspaceTabIndex}">
                    <TabItem Header="Automation">
                    <Grid ColumnDefinitions="*,*"
                          Margin="0,6,0,0">
                    <Border Grid.Column="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,0,8,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Family Coverage"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding FamilyCoverage}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FamilyCoverageItemViewModel">
                                        <Grid ColumnDefinitions="*,Auto"
                                              Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Family}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Progress}"
                                                       FontWeight="Bold" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="8,0,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Workflow Actions"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <Border Background="{DynamicResource AccentAuditBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <TextBlock Text="{Binding AutomationModeSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </Border>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <TextBlock Text="{Binding AutomationSafetySummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Stop All Automation"
                                        Command="{Binding StopAllAutomationCommand}" />
                            </Grid>
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <TextBlock Text="Visible AI Queue"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource AccentPillBrush}"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AutomationQueueSummary}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding AutomationQueueHint}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Queue Selected Request"
                                                Command="{Binding QueueSelectedRequestForAutomationCommand}" />
                                        <Button Content="Take Manual Control"
                                                Command="{Binding TakeManualControlCommand}" />
                                        <Button Content="Return To Assisted AI"
                                                Command="{Binding ReturnToAssistedAiCommand}" />
                                    </StackPanel>
                                    <ListBox ItemsSource="{Binding AutomationQueueItems}"
                                             SelectedItem="{Binding SelectedAutomationTaskItem}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MinHeight="140"
                                             MaxHeight="240">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:AutomationTaskItemViewModel">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10"
                                                        Margin="0,0,0,8">
                                                    <StackPanel Spacing="4">
                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="10">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="Bold"
                                                                       TextWrapping="Wrap" />
                                                            <Border Grid.Column="1"
                                                                    Background="{DynamicResource AccentPillBrush}"
                                                                    CornerRadius="999"
                                                                    Padding="10,4">
                                                                <TextBlock Text="{Binding StatusLabel}" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding TargetScope}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding TypeLabel}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding LinkedCandidateSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding LatestActivitySummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding UpdatedLabel}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBlock Text="{Binding SelectedAutomationTaskSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Current AI Focus"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding SelectedAutomationTaskActivitySummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SelectedAutomationTaskCandidateSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Prompt Preview"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding SelectedAutomationTaskPromptSummary}"
                                                               FontFamily="Consolas"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Grid ColumnDefinitions="*,*,*,*"
                                                  ColumnSpacing="8">
                                                <Button Content="Generated"
                                                        Command="{Binding RecordSelectedAutomationGeneratedCommand}" />
                                                <Button Grid.Column="1"
                                                        Content="Needs Touchup"
                                                        Command="{Binding RecordSelectedAutomationNeedsManualTouchupCommand}" />
                                                <Button Grid.Column="2"
                                                        Content="Rejected"
                                                        Command="{Binding RecordSelectedAutomationRejectedCommand}" />
                                                <Button Grid.Column="3"
                                                        Content="Approved"
                                                        Command="{Binding RecordSelectedAutomationApprovedCommand}" />
                                            </Grid>
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="AI Attempt Trail"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding SelectedAutomationTaskHistorySummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ItemsControl ItemsSource="{Binding SelectedAutomationTaskHistoryItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:RequestHistoryItemViewModel">
                                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="8"
                                                                        Margin="0,0,0,6">
                                                                    <StackPanel Spacing="4">
                                                                        <Grid ColumnDefinitions="Auto,*"
                                                                              ColumnSpacing="8">
                                                                            <Border Background="{DynamicResource AccentPillBrush}"
                                                                                    CornerRadius="999"
                                                                                    Padding="8,3">
                                                                                <TextBlock Text="{Binding EventTypeLabel}" />
                                                                            </Border>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding UpdatedLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       VerticalAlignment="Center" />
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding Message}"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Linked Candidates"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding SelectedAutomationTaskLinkedCandidatesSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ItemsControl ItemsSource="{Binding SelectedAutomationTaskCandidates}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:CandidateItemViewModel">
                                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="8"
                                                                        Margin="0,0,0,6">
                                                                    <StackPanel Spacing="4">
                                                                        <Grid ColumnDefinitions="*,Auto"
                                                                              ColumnSpacing="8">
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontWeight="Bold"
                                                                                       TextWrapping="Wrap" />
                                                                            <Border Grid.Column="1"
                                                                                    Background="{DynamicResource AccentPillBrush}"
                                                                                    CornerRadius="999"
                                                                                    Padding="8,3">
                                                                                <TextBlock Text="{Binding StatusLabel}" />
                                                                            </Border>
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding NotePreview}"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Spacing="8">
                                                                            <Button Content="Focus"
                                                                                    Command="{Binding #Root.DataContext.FocusAutomationCandidateCommand}"
                                                                                    CommandParameter="{Binding .}" />
                                                                            <Button Content="Load Into Paint"
                                                                                    Command="{Binding #Root.DataContext.LoadAutomationCandidateIntoPaintCommand}"
                                                                                    CommandParameter="{Binding .}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="Start"
                                                Command="{Binding StartSelectedAutomationTaskCommand}" />
                                        <Button Content="Pause"
                                                Command="{Binding PauseSelectedAutomationTaskCommand}" />
                                        <Button Content="Resume Queue"
                                                Command="{Binding ResumeSelectedAutomationTaskCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding WorkflowActions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:WorkflowActionItemViewModel">
                                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="10">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="1"
                                                            Background="{DynamicResource AccentPillBrush}"
                                                            CornerRadius="999"
                                                            Padding="10,4"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ExecutionModeLabel}" />
                                                    </Border>
                                                    <Border Grid.Column="2"
                                                            Background="{DynamicResource AccentPillBrush}"
                                                            CornerRadius="999"
                                                            Padding="10,4"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusLabel}" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding ActionHint}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Command}" />
                                                <TextBlock Text="{Binding ArgumentsDisplay}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding WorkingDirectory}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding LastRunLabel}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10">
                                                    <TextBlock Text="{Binding LastOutputPreview}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button Content="Open Folder"
                                                            Command="{Binding #Root.DataContext.OpenWorkflowActionFolderCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    <Button Content="Run Hidden"
                                                            IsVisible="{Binding CanRunHidden}"
                                                            Command="{Binding #Root.DataContext.RunWorkflowActionCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    <Button Content="Stop"
                                                            IsVisible="{Binding CanStop}"
                                                            Command="{Binding #Root.DataContext.StopWorkflowActionCommand}"
                                                            CommandParameter="{Binding .}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    </Grid>
                    </TabItem>

                    <TabItem Header="Review">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,6,0,0">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Review and Choose a Row"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="Start here. Pick a sprite row, inspect its notes and coverage, then jump into Studio when you want to preview or edit it."
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentPillBrush}"
                                    CornerRadius="999"
                                    Padding="12,6"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding AssetBrowserSummary}"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Species"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding SpeciesFilterOptions}"
                                          SelectedItem="{Binding SelectedSpeciesFilter}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Family"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding FamilyFilterOptions}"
                                          SelectedItem="{Binding SelectedFamilyFilter}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Spacing="6">
                                <TextBlock Text="Coverage"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding CoverageStatusFilterOptions}"
                                          SelectedItem="{Binding SelectedCoverageStatusFilter}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Spacing="6">
                                <TextBlock Text="Review"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding ReviewStatusFilterOptions}"
                                          SelectedItem="{Binding SelectedReviewStatusFilter}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="1.2*,1.05*"
                              ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="2*,Auto,3*">
                                        <TextBlock Text="Variant"
                                                   FontWeight="Bold" />
                                        <TextBlock Grid.Column="1"
                                                   Text="Status"
                                                   FontWeight="Bold"
                                                   Margin="12,0,0,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="Family Coverage"
                                                   FontWeight="Bold"
                                                   Margin="12,0,0,0" />
                                    </Grid>

                                    <ListBox ItemsSource="{Binding FilteredBaseVariants}"
                                             SelectedItem="{Binding SelectedBaseVariant}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MinHeight="340">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:BaseVariantRowItemViewModel">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <StackPanel Spacing="10">
                                                        <Grid ColumnDefinitions="2*,Auto,3*"
                                                              ColumnSpacing="12">
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="Bold" />
                                                                <TextBlock Text="{Binding QualitySummary}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                <TextBlock Text="{Binding FrameReviewSummary}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding ExpectedColors, StringFormat='{}{0} color variants'}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            </StackPanel>
                                                            <Border Grid.Column="1"
                                                                    Background="{DynamicResource AccentPillBrush}"
                                                                    CornerRadius="999"
                                                                    Padding="10,4"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding StatusLabel}" />
                                                            </Border>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding FamilySummary}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding ReviewNotePreview}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding FrameIssueSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Selected Row"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <Border Grid.Column="1"
                                                Background="{DynamicResource AccentPillBrush}"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedBaseVariantStatus}" />
                                        </Border>
                                    </Grid>

                                    <Border Background="{DynamicResource AccentAuditBrush}"
                                            CornerRadius="12"
                                            Padding="12">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding SelectedBaseVariantTitle}"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding AuditProgressSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*,*"
                                                  ColumnSpacing="8">
                                                <Button Content="Prev Row"
                                                        Command="{Binding SelectPreviousVariantCommand}" />
                                                <Button Grid.Column="1"
                                                        Content="Next Needs Work"
                                                        Command="{Binding SelectNextNeedsReviewVariantCommand}" />
                                                <Button Grid.Column="2"
                                                        Content="Next Row"
                                                        Command="{Binding SelectNextVariantCommand}" />
                                            </Grid>
                                            <TextBlock Text="Shortcuts: Ctrl+Left prev  |  Ctrl+Right next  |  Ctrl+Shift+Right next needs work  |  Ctrl+1 approve  |  Ctrl+2 needs review  |  Ctrl+3 to repair"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,*,*"
                                                  ColumnSpacing="8">
                                                <Button Content="Preview In Animate"
                                                        Command="{Binding OpenAnimateWorkspaceCommand}" />
                                                <Button Grid.Column="1"
                                                        Content="Edit Current Frame"
                                                        Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                                                <Button Grid.Column="2"
                                                        Content="Save Review"
                                                        Command="{Binding SaveReviewCommand}" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <TabControl>
                                        <TabItem Header="Details">
                                            <StackPanel Spacing="10"
                                                        Margin="0,10,0,0">
                                                <TextBlock Text="{Binding SelectedBaseVariantSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SelectedBaseVariantReviewSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SelectedBaseVariantFrameQualitySummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding SelectedBaseVariantFrameIssueSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <ItemsControl ItemsSource="{Binding SelectedBaseVariantFamilyProgress}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:FamilyProgressItemViewModel">
                                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="12"
                                                                    Margin="0,0,0,8">
                                                                <Grid ColumnDefinitions="*,Auto">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="{Binding Family}"
                                                                                   FontWeight="Bold" />
                                                                        <TextBlock Text="Complete colors"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Progress}"
                                                                               FontWeight="Bold"
                                                                               VerticalAlignment="Center" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </TabItem>

                                        <TabItem Header="Notes">
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12"
                                                    Margin="0,10,0,0">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Review"
                                                               FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding ReviewStatusOptions}"
                                                              SelectedItem="{Binding SelectedBaseVariant.ReviewStatus}"
                                                              MinWidth="180" />
                                                    <TextBox Text="{Binding SelectedBaseVariant.ReviewNote}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="160" />
                                                    <TextBlock Text="{Binding SelectedBaseVariant.ReviewUpdatedLabel}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding ReviewDataPathDisplay}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding ReviewSaveMessage}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <Grid ColumnDefinitions="*,*,*"
                                                          ColumnSpacing="8">
                                                        <Button Content="Approve"
                                                                Command="{Binding MarkSelectedApprovedCommand}" />
                                                        <Button Grid.Column="1"
                                                                Content="Needs Review"
                                                                Command="{Binding MarkSelectedNeedsReviewCommand}" />
                                                        <Button Grid.Column="2"
                                                                Content="To Repair"
                                                                Command="{Binding MarkSelectedToBeRepairedCommand}" />
                                                    </Grid>
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <Button Content="Create Request"
                                                                Command="{Binding CreateRequestFromSelectedCommand}" />
                                                        <Button Content="Clear Review"
                                                                Command="{Binding ClearSelectedReviewCommand}" />
                                                        <Button Content="Save Review"
                                                                Command="{Binding SaveReviewCommand}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </TabItem>

                                        <TabItem Header="Current Frame">
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12"
                                                    Margin="0,10,0,0">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Frame Review"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding CurrentFrameReviewTargetSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding CurrentFrameReviewSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ComboBox ItemsSource="{Binding FrameReviewStatusOptions}"
                                                              SelectedItem="{Binding SelectedFrameReviewStatus}"
                                                              MinWidth="180" />
                                                    <TextBox Text="{Binding SelectedFrameReviewNote}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="120" />
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Issue Tags"
                                                                   FontWeight="Bold" />
                                                        <TextBox Text="{Binding SelectedFrameIssueTagsText}"
                                                                 Watermark="off_model, broken_outline, placeholder"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 MinHeight="64" />
                                                        <WrapPanel ItemHeight="32"
                                                                   ItemWidth="150">
                                                            <Button Content="off_model"
                                                                    Command="{Binding AddCurrentFrameIssueTagCommand}"
                                                                    CommandParameter="off_model" />
                                                            <Button Content="stiff_motion"
                                                                    Command="{Binding AddCurrentFrameIssueTagCommand}"
                                                                    CommandParameter="stiff_motion" />
                                                            <Button Content="broken_outline"
                                                                    Command="{Binding AddCurrentFrameIssueTagCommand}"
                                                                    CommandParameter="broken_outline" />
                                                            <Button Content="wrong_silhouette"
                                                                    Command="{Binding AddCurrentFrameIssueTagCommand}"
                                                                    CommandParameter="wrong_silhouette" />
                                                            <Button Content="placeholder"
                                                                    Command="{Binding AddCurrentFrameIssueTagCommand}"
                                                                    CommandParameter="placeholder" />
                                                            <Button Content="anthropomorphic_drift"
                                                                    Command="{Binding AddCurrentFrameIssueTagCommand}"
                                                                    CommandParameter="anthropomorphic_drift" />
                                                        </WrapPanel>
                                                        <Button Content="Clear Tags"
                                                                HorizontalAlignment="Left"
                                                                Command="{Binding ClearCurrentFrameIssueTagsCommand}" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CurrentFrameReviewUpdatedLabel}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding FrameReviewSaveMessage}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <Grid ColumnDefinitions="*,*,*,*"
                                                          ColumnSpacing="8">
                                                        <Button Content="Approve"
                                                                Command="{Binding MarkCurrentFrameApprovedCommand}" />
                                                        <Button Grid.Column="1"
                                                                Content="Needs Review"
                                                                Command="{Binding MarkCurrentFrameNeedsReviewCommand}" />
                                                        <Button Grid.Column="2"
                                                                Content="To Repair"
                                                                Command="{Binding MarkCurrentFrameToBeRepairedCommand}" />
                                                        <Button Grid.Column="3"
                                                                Content="Template Only"
                                                                Command="{Binding MarkCurrentFrameTemplateOnlyCommand}" />
                                                    </Grid>
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <Button Content="Create Request From Frame"
                                                                Command="{Binding CreateRequestFromCurrentFrameCommand}" />
                                                        <Button Content="Save Frame Review"
                                                                Command="{Binding SaveCurrentFrameReviewCommand}" />
                                                        <Button Content="Clear Frame Review"
                                                                Command="{Binding ClearCurrentFrameReviewCommand}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </TabItem>

                                        <TabItem Header="Queue Context">
                                            <StackPanel Spacing="10"
                                                        Margin="0,10,0,0">
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="10">
                                                    <Border Background="{DynamicResource AccentPillBrush}"
                                                            CornerRadius="999"
                                                            Padding="10,4">
                                                        <TextBlock Text="{Binding RepairQueueSummary}" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding NeedsReviewSummary}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </Grid>
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="Auto,*"
                                                              ColumnSpacing="10">
                                                            <Border Background="{DynamicResource AccentPillBrush}"
                                                                    CornerRadius="999"
                                                                    Padding="10,4">
                                                                <TextBlock Text="{Binding FrameReviewQueueSummary}" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="Frame-level issues appear here so you can jump directly into the exact slot that needs work."
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                        <ListBox ItemsSource="{Binding FrameReviewQueueItems}"
                                                                 SelectedItem="{Binding SelectedFrameReviewQueueItem}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 MinHeight="160"
                                                                 MaxHeight="240">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:FrameReviewQueueItemViewModel">
                                                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10"
                                                                            Padding="10"
                                                                            Margin="0,0,0,8">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Text="{Binding DisplayName}"
                                                                                       FontWeight="Bold"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding TargetSummary}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding IssueTagSummary}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding NotePreview}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </StackPanel>
                                                </Border>
                                                <ListBox ItemsSource="{Binding RepairQueueItems}"
                                                         SelectedItem="{Binding SelectedRepairQueueItem}"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         MinHeight="180"
                                                         MaxHeight="260">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:BaseVariantRowItemViewModel">
                                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="10"
                                                                    Margin="0,0,0,8">
                                                                <StackPanel Spacing="4">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontWeight="Bold" />
                                                                    <TextBlock Text="{Binding ReviewStatusLabel}"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                    <TextBlock Text="{Binding ReviewNotePreview}"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                                <Button Content="Create Request From Queue"
                                                        HorizontalAlignment="Left"
                                                        Command="{Binding CreateRequestFromRepairQueueCommand}" />
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                    </Border>
                    </TabItem>

                    <TabItem Header="Queue">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,6,0,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Repair Queue"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="Rows marked for repair stay here until they are fixed or reclassified."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Spacing="4"
                                        HorizontalAlignment="Right">
                                <Border Background="{DynamicResource AccentPillBrush}"
                                        CornerRadius="999"
                                        Padding="12,6">
                                    <TextBlock Text="{Binding RepairQueueSummary}"
                                               FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="{Binding NeedsReviewSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right" />
                                <Button Content="Create Request From Queue"
                                        Command="{Binding CreateRequestFromRepairQueueCommand}" />
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Trusted Export"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding TrustedExportSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TrustedExportHint}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TrustedExportBlockerSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TrustedExportDirectoryDisplay}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Export Trusted Set"
                                            Command="{Binding ExportTrustedSetCommand}" />
                                    <Button Content="Open Trusted Folder"
                                            Command="{Binding OpenTrustedExportFolderCommand}" />
                                    <Button Content="Open Selected Export"
                                            Command="{Binding OpenSelectedTrustedExportCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding TrustedExportMessage}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TrustedExportHistorySummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <TextBlock Text="{Binding TrustedExportBlockerListSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="Jump To Blocker"
                                            Command="{Binding JumpToSelectedTrustedExportBlockerCommand}" />
                                </Grid>
                                <ListBox ItemsSource="{Binding TrustedExportBlockers}"
                                         SelectedItem="{Binding SelectedTrustedExportBlockerItem}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxHeight="180">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TrustedExportBlockerItemViewModel">
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="8">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="Bold"
                                                                   TextWrapping="Wrap" />
                                                        <Border Grid.Column="1"
                                                                Background="{DynamicResource AccentAlertBrush}"
                                                                CornerRadius="999"
                                                                Padding="8,3">
                                                            <TextBlock Text="{Binding ScopeLabel}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding TargetSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Reason}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ListBox ItemsSource="{Binding TrustedExportHistoryItems}"
                                         SelectedItem="{Binding SelectedTrustedExportHistoryItem}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxHeight="180">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TrustedExportHistoryItemViewModel">
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Summary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding UpdatedLabel}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <ListBox ItemsSource="{Binding RepairQueueItems}"
                                 SelectedItem="{Binding SelectedRepairQueueItem}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MinHeight="150">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:BaseVariantRowItemViewModel">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="Bold" />
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource AccentAlertBrush}"
                                                        CornerRadius="999"
                                                        Padding="10,4">
                                                    <TextBlock Text="{Binding ReviewStatusLabel}" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding FamilySummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ReviewNotePreview}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                    </Border>
                    </TabItem>

                    <TabItem Header="Requests">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,6,0,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Requests"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="Turn repair notes or new asset ideas into saved, AI-ready request records."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentPillBrush}"
                                    CornerRadius="999"
                                    Padding="12,6">
                                <TextBlock Text="{Binding RequestSummary}"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="0.95*,1.05*"
                              ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Saved Requests"
                                               FontSize="16"
                                               FontWeight="Bold" />
                                    <ListBox ItemsSource="{Binding Requests}"
                                             SelectedItem="{Binding SelectedRequestItem}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MinHeight="220">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:RequestItemViewModel">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <StackPanel Spacing="6">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="Bold"
                                                                       TextWrapping="Wrap" />
                                                            <Border Grid.Column="1"
                                                                    Background="{DynamicResource AccentPillBrush}"
                                                                    CornerRadius="999"
                                                                    Padding="10,4">
                                                                <TextBlock Text="{Binding StatusLabel}" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding TypeLabel}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding TargetScope}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding UpdatedLabel}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12">
                                <TabControl>
                                    <TabItem Header="Request Draft">
                                        <StackPanel Spacing="10"
                                                    Margin="0,10,0,0">
                                            <TextBlock Text="Request Draft"
                                                       FontSize="16"
                                                       FontWeight="Bold" />
                                            <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Type"
                                                               FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding RequestTypeOptions}"
                                                              SelectedItem="{Binding DraftRequestType}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="6">
                                                    <TextBlock Text="Status"
                                                               FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding RequestStatusOptions}"
                                                              SelectedItem="{Binding DraftRequestStatus}" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Title"
                                                           FontWeight="Bold" />
                                                <TextBox Text="{Binding DraftRequestTitle}" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Target Scope"
                                                           FontWeight="Bold" />
                                                <TextBox Text="{Binding DraftRequestTargetScope}" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Details"
                                                           FontWeight="Bold" />
                                                <TextBox Text="{Binding DraftRequestDetails}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="90" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Must Preserve"
                                                           FontWeight="Bold" />
                                                <TextBox Text="{Binding DraftRequestMustPreserve}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="70" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Must Avoid"
                                                           FontWeight="Bold" />
                                                <TextBox Text="{Binding DraftRequestMustAvoid}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="70" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Source Note"
                                                           FontWeight="Bold" />
                                                <TextBox Text="{Binding DraftRequestSourceNote}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         MinHeight="70" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding RequestDataPathDisplay}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding RequestExportPathDisplay}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding RequestSaveMessage}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="AI Handoff Preview"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding DraftRequestPreview}"
                                                               FontFamily="Consolas"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <Button Content="Prefill From Selected Row"
                                                        Command="{Binding CreateRequestFromSelectedCommand}" />
                                                <Button Content="Clear Draft"
                                                        Command="{Binding ClearRequestDraftCommand}" />
                                                <Button Content="Export Handoff"
                                                        Command="{Binding ExportDraftRequestCommand}" />
                                                <Button Content="Save Request"
                                                        Command="{Binding SaveRequestCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="Request Activity">
                                        <StackPanel Spacing="10"
                                                    Margin="0,10,0,0">
                                            <TextBlock Text="Request Activity"
                                                       FontSize="16"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding SelectedRequestHistorySummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Current Prompt Preview"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding DraftRequestPreview}"
                                                               FontFamily="Consolas"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Saved Activity Trail"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="Queue changes, AI handoff steps, exports, and candidate imports are recorded here for the selected request."
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ItemsControl ItemsSource="{Binding SelectedRequestItem.History}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:RequestHistoryItemViewModel">
                                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Padding="10"
                                                                        Margin="0,0,0,8">
                                                                    <StackPanel Spacing="4">
                                                                        <Grid ColumnDefinitions="Auto,*"
                                                                              ColumnSpacing="8">
                                                                            <Border Background="{DynamicResource AccentPillBrush}"
                                                                                    CornerRadius="999"
                                                                                    Padding="8,3">
                                                                                <TextBlock Text="{Binding EventTypeLabel}" />
                                                                            </Border>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding UpdatedLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       VerticalAlignment="Center" />
                                                                        </Grid>
                                                                        <TextBlock Text="{Binding Message}"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </TabItem>

                                    <TabItem Header="Candidate Staging">
                                        <StackPanel Spacing="10"
                                                    Margin="0,10,0,0">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Candidate Staging"
                                                               FontSize="16"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="Stage alternates before approving them into the trusted workflow."
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource AccentPillBrush}"
                                                        CornerRadius="999"
                                                        Padding="12,6">
                                                    <TextBlock Text="{Binding CandidateSummary}"
                                                               FontWeight="Bold" />
                                                </Border>
                                            </Grid>

                                            <Grid ColumnDefinitions="0.92*,1.08*"
                                                  ColumnSpacing="12">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12">
                                                    <StackPanel Spacing="8">
                                                        <ListBox ItemsSource="{Binding Candidates}"
                                                                 SelectedItem="{Binding SelectedCandidateItem}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 MinHeight="220">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:CandidateItemViewModel">
                                                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="10"
                                                                            Padding="10"
                                                                            Margin="0,0,0,8">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontWeight="Bold"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding StatusLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding SourceTypeLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding NotePreview}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                        <Grid ColumnDefinitions="*,*"
                                                              ColumnSpacing="8">
                                                            <Button Content="Stage Current Authored"
                                                                    Command="{Binding StageCurrentAuthoredCandidateCommand}" />
                                                            <Button Grid.Column="1"
                                                                    Content="Stage Runtime"
                                                                    Command="{Binding StageRuntimeCandidateCommand}" />
                                                        </Grid>
                                                        <Button Content="Stage Live Editor"
                                                                Command="{Binding StageEditorCanvasCandidateCommand}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="12">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="{Binding SelectedCandidateSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding SelectedCandidateTargetSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <Grid ColumnDefinitions="*,*"
                                                              ColumnSpacing="10">
                                                            <StackPanel Spacing="6"
                                                                        HorizontalAlignment="Center">
                                                                <TextBlock Text="Candidate"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center" />
                                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Padding="8">
                                                                    <Grid Width="180"
                                                                          Height="180">
                                                                        <Image Source="{Binding SelectedCandidateBitmap}"
                                                                               Stretch="Uniform"
                                                                               IsVisible="{Binding HasSelectedCandidateBitmap}" />
                                                                        <TextBlock Text="No candidate image"
                                                                                   IsVisible="{Binding IsSelectedCandidateBitmapMissing}"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        Spacing="6"
                                                                        HorizontalAlignment="Center">
                                                                <TextBlock Text="Reference"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center" />
                                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="10"
                                                                        Padding="8">
                                                                    <Grid Width="180"
                                                                          Height="180">
                                                                        <Image Source="{Binding SelectedCandidateReferenceBitmap}"
                                                                               Stretch="Uniform"
                                                                               IsVisible="{Binding HasSelectedCandidateReferenceBitmap}" />
                                                                        <TextBlock Text="No reference image"
                                                                                   IsVisible="{Binding IsSelectedCandidateReferenceBitmapMissing}"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                        <ComboBox ItemsSource="{Binding CandidateStatusOptions}"
                                                                  SelectedItem="{Binding SelectedCandidateItem.Status}"
                                                                  MinWidth="180" />
                                                        <TextBox Text="{Binding SelectedCandidateItem.Note}"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 MinHeight="100" />
                                                        <TextBlock Text="{Binding CandidateDataPathDisplay}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding CandidateAssetDirectoryDisplay}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding SelectedCandidateItem.BackupSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding CandidateSaveMessage}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <Grid ColumnDefinitions="*,*,*"
                                                              ColumnSpacing="8">
                                                            <Button Content="Approve"
                                                                    Command="{Binding MarkSelectedCandidateApprovedCommand}" />
                                                            <Button Grid.Column="1"
                                                                    Content="Reject"
                                                                    Command="{Binding MarkSelectedCandidateRejectedCommand}" />
                                                            <Button Grid.Column="2"
                                                                    Content="Load Into Paint"
                                                                    Command="{Binding LoadSelectedCandidateIntoPaintCommand}" />
                                                        </Grid>
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8">
                                                            <Button Content="Create Request From Candidate"
                                                                    Command="{Binding CreateRequestFromSelectedCandidateCommand}" />
                                                            <Button Content="Apply To Current Frame"
                                                                    Command="{Binding ApplySelectedCandidateToCurrentFrameCommand}" />
                                                            <Button Content="Restore Backup"
                                                                    Command="{Binding RestoreSelectedCandidateBackupCommand}" />
                                                            <Button Content="Save Candidate"
                                                                    Command="{Binding SaveSelectedCandidateCommand}" />
                                                            <Button Content="Delete Candidate"
                                                                    Command="{Binding DeleteSelectedCandidateCommand}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </TabItem>
                                </TabControl>
                            </Border>
                        </Grid>
                    </StackPanel>
                    </Border>
                    </TabItem>

                    <TabItem Header="Studio">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,6,0,0">
                        <TabControl Margin="0,6,0,0"
                                    SelectedIndex="{Binding SelectedStudioTabIndex}">
                        <TabItem Header="Animate">
                            <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Animate and Compare"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="Preview the selected row in motion, compare authored against runtime, then jump into Paint when a frame needs work."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CoreLoopSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button Content="Blink Compare"
                                        Command="{Binding ToggleBlinkCompareCommand}" />
                                <Button Content="Play"
                                        Command="{Binding PlayPreviewCommand}" />
                                <Button Content="Pause On Frame"
                                        Command="{Binding PausePreviewCommand}" />
                                <Button Content="Prev"
                                        Command="{Binding StepPreviousFrameCommand}" />
                                <Button Content="Restart"
                                        Command="{Binding RestartPreviewCommand}" />
                                <Button Content="Next"
                                        Command="{Binding StepNextFrameCommand}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Studio shortcuts: [ prev frame  |  ] next frame  |  \\ restart  |  Ctrl+Alt+Left prev->current  |  Ctrl+Alt+Right current->next  |  Ctrl+Alt+Up swap with prev  |  B brush  |  E erase  |  I dropper  |  F fill  |  Ctrl+Z undo  |  Ctrl+Y redo  |  Ctrl+Plus / Ctrl+Minus zoom"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <Border Background="{DynamicResource AccentPillBrush}"
                                CornerRadius="999"
                                Padding="12,6"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ViewerSelectionSummary}"
                                       FontWeight="Bold" />
                        </Border>
                        <TextBlock Text="{Binding PlaybackModeSummary}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ViewerEditHint}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <Border Background="{DynamicResource AccentAuditBrush}"
                                CornerRadius="12"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Visible AI / Manual Handoff"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding StudioAiHandoffSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding StudioCandidateHandoffSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <ComboBox ItemsSource="{Binding FrameReviewStatusOptions}"
                                          SelectedItem="{Binding SelectedFrameReviewStatus}"
                                          MinWidth="180"
                                          MaxWidth="260" />
                                <TextBox Text="{Binding SelectedFrameReviewNote}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="72"
                                         Watermark="Describe what needs work on this frame..." />
                                <TextBox Text="{Binding SelectedFrameIssueTagsText}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="52"
                                         Watermark="off_model, broken_outline, placeholder" />
                                <TextBlock Text="{Binding FrameReviewSaveMessage}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Create Request From Frame"
                                            Command="{Binding CreateRequestFromCurrentFrameCommand}" />
                                    <Button Content="Queue Selected Request"
                                            Command="{Binding QueueSelectedRequestForAutomationCommand}" />
                                    <Button Content="Stage Authored"
                                            Command="{Binding StageCurrentAuthoredCandidateCommand}" />
                                    <Button Content="Stage Runtime"
                                            Command="{Binding StageRuntimeCandidateCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Approve Frame"
                                            Command="{Binding MarkCurrentFrameApprovedCommand}" />
                                    <Button Content="Needs Review"
                                            Command="{Binding MarkCurrentFrameNeedsReviewCommand}" />
                                    <Button Content="To Repair"
                                            Command="{Binding MarkCurrentFrameToBeRepairedCommand}" />
                                    <Button Content="Template Only"
                                            Command="{Binding MarkCurrentFrameTemplateOnlyCommand}" />
                                    <Button Content="Save Frame Review"
                                            Command="{Binding SaveCurrentFrameReviewCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Take Manual Control"
                                            Command="{Binding TakeManualControlCommand}" />
                                    <Button Content="Return To Assisted AI"
                                            Command="{Binding ReturnToAssistedAiCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*,Auto,Auto"
                              ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Color"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding ViewerColorOptions}"
                                          SelectedItem="{Binding SelectedViewerColor}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Family"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding ViewerFamilyOptions}"
                                          SelectedItem="{Binding SelectedViewerFamily}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Spacing="6">
                                <TextBlock Text="Sequence"
                                           FontWeight="Bold" />
                                <ComboBox ItemsSource="{Binding ViewerSequenceOptions}"
                                          SelectedItem="{Binding SelectedViewerSequenceId}"
                                          MinWidth="130" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Spacing="6"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text="Playback"
                                           FontWeight="Bold" />
                                <CheckBox Content="Play automatically"
                                          IsChecked="{Binding IsPlaybackEnabled}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="16">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Speed"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Slider Width="180"
                                        Minimum="80"
                                        Maximum="500"
                                        Value="{Binding PreviewPlaybackMs}" />
                                <TextBlock Text="{Binding PlaybackSpeedSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <CheckBox Content="Onion Skin"
                                      IsChecked="{Binding IsOnionSkinEnabled}" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Opacity"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Slider Width="160"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding OnionSkinOpacity}" />
                                <TextBlock Text="{Binding OnionSkinSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*,*,*,*"
                              ColumnSpacing="8">
                            <Button Content="Use Prev -> Current"
                                    Command="{Binding CopyPreviousFrameIntoCurrentCommand}" />
                            <Button Grid.Column="1"
                                    Content="Duplicate Current -> Next"
                                    Command="{Binding DuplicateCurrentFrameToNextCommand}" />
                            <Button Grid.Column="2"
                                    Content="Swap Current &lt;-&gt; Prev"
                                    Command="{Binding SwapCurrentFrameWithPreviousCommand}" />
                            <Button Grid.Column="3"
                                    Content="Create Blank Frame"
                                    Command="{Binding CreateBlankCurrentFrameCommand}" />
                            <Button Grid.Column="4"
                                    Content="Edit Current In Paint"
                                    Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                        </Grid>

                        <Grid ColumnDefinitions="1.1*,0.9*"
                              ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="{Binding ViewerStatusMessage}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />

                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18"
                                            MinHeight="340">
                                        <Grid ColumnDefinitions="1.15*,0.85*,0.95*"
                                              ColumnSpacing="14">
                                            <StackPanel Spacing="10"
                                                        HorizontalAlignment="Center">
                                                <Border Background="{DynamicResource AccentPillBrush}"
                                                        CornerRadius="999"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="Authored - Current Edit Target"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                </Border>
                                                <Grid Width="320"
                                                      Height="320"
                                                      HorizontalAlignment="Center">
                                                    <Image Source="{Binding OnionSkinBitmap}"
                                                           Width="320"
                                                           Height="320"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Opacity="{Binding OnionSkinOpacityFraction}"
                                                           IsVisible="{Binding HasOnionSkinBitmap}" />
                                                    <Image Source="{Binding CurrentFrameBitmap}"
                                                           Width="320"
                                                           Height="320"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                    <TextBlock Text="No authored frame"
                                                               IsVisible="{Binding IsCurrentFrameBitmapMissing}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <TextBlock Text="{Binding ViewerFrameSummary}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding CurrentFrameActionSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="320" />
                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10"
                                                        MaxWidth="320">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="Current Frame Review"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="{Binding CurrentFrameReviewSummary}"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding CurrentFrameReviewTargetSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10"
                                                        MaxWidth="320">
                                                    <StackPanel Spacing="6"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="Blink Compare"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center" />
                                                        <Grid Width="220"
                                                              Height="220">
                                                            <Image Source="{Binding BlinkCompareBitmap}"
                                                                   Width="220"
                                                                   Height="220"
                                                                   Stretch="Uniform"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                            <TextBlock Text="Need authored and runtime frames"
                                                                       IsVisible="{Binding IsRuntimeFrameBitmapMissing}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       TextAlignment="Center" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding BlinkCompareSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8"
                                                      MaxWidth="320">
                                                    <Button Content="Pause On This Frame"
                                                            Command="{Binding PausePreviewCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Edit This Frame"
                                                            Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8"
                                                      MaxWidth="320">
                                                    <Button Content="Create Blank Here"
                                                            Command="{Binding CreateBlankCurrentFrameCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Create Blank Sequence"
                                                            Command="{Binding CreateBlankCurrentSequenceCommand}" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="10"
                                                        HorizontalAlignment="Center">
                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="Runtime Reference"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                </Border>
                                                <Grid Width="256"
                                                      Height="256"
                                                      HorizontalAlignment="Center">
                                                    <Image Source="{Binding RuntimeFrameBitmap}"
                                                           Width="256"
                                                           Height="256"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                            IsVisible="{Binding HasRuntimeFrameBitmap}" />
                                                    <TextBlock Text="No runtime frame"
                                                               IsVisible="{Binding IsRuntimeFrameBitmapMissing}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <TextBlock Text="{Binding RuntimeViewerFrameSummary}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding RuntimeTemplateActionSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="256" />
                                                <Button Content="Use Runtime As Template"
                                                        Command="{Binding LoadRuntimeFrameIntoEditorCommand}"
                                                        HorizontalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Spacing="10"
                                                        HorizontalAlignment="Center">
                                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="Live Playback"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                </Border>
                                                <Grid Width="256"
                                                      Height="256"
                                                      HorizontalAlignment="Center">
                                                    <Image Source="{Binding PlaybackFrameBitmap}"
                                                           Width="256"
                                                           Height="256"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding HasPlaybackFrameBitmap}" />
                                                    <TextBlock Text="No authored playback frame"
                                                               IsVisible="{Binding IsPlaybackFrameBitmapMissing}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center" />
                                                </Grid>
                                                <TextBlock Text="{Binding LivePlaybackSummary}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="256" />
                                                <TextBlock Text="{Binding LivePlaybackActionSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="256" />
                                                <TextBlock Text="{Binding RuntimePlaybackSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxWidth="256" />
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8"
                                                      MaxWidth="256">
                                                    <Button Content="Play"
                                                            Command="{Binding PlayPreviewCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Use Live As Edit Target"
                                                            Command="{Binding UsePlaybackFrameAsEditTargetCommand}" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="{Binding ViewerMissingSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ViewerFramePath}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding RuntimeViewerFramePath}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Timeline"
                                               FontSize="16"
                                               FontWeight="Bold" />
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding ViewerFrames}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ViewerFrameItemViewModel">
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{Binding FrameBorderBrush}"
                                                            BorderThickness="{Binding FrameBorderThickness}"
                                                            CornerRadius="10"
                                                            Padding="8"
                                                            Margin="0,0,8,0"
                                                            Width="112">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="{Binding FrameId}"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       TextAlignment="Center" />
                                                            <TextBlock Text="{Binding ReviewStatusLabel}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Center"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap" />
                                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Width="84"
                                                                    Height="84"
                                                                    HorizontalAlignment="Center">
                                                                <Grid>
                                                                    <Image Source="{Binding ThumbnailBitmap}"
                                                                           Width="80"
                                                                           Height="80"
                                                                           Stretch="Uniform"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding ThumbnailLabel}"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               FontSize="10"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Bottom"
                                                                               Margin="0,0,0,4" />
                                                                </Grid>
                                                            </Border>
                                                            <TextBlock Text="{Binding IssueTagSummary}"
                                                                       IsVisible="{Binding HasIssueTags}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Center"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       MaxWidth="96" />
                                                            <Button Content="Show"
                                                                    Command="{Binding #Root.DataContext.SelectViewerFrameCommand}"
                                                                    CommandParameter="{Binding FrameIndex}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBlock Text="Frame Slots"
                                               FontSize="16"
                                               FontWeight="Bold" />
                                    <ItemsControl ItemsSource="{Binding ViewerFrames}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ViewerFrameItemViewModel">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                                          ColumnSpacing="10">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding FrameId}"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text="{Binding StateLabel}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding RuntimeStateLabel}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding ReviewStatusLabel}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding IssueTagSummary}"
                                                                       IsVisible="{Binding HasIssueTags}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Marker}"
                                                                   VerticalAlignment="Center" />
                                                        <Button Grid.Column="2"
                                                                Content="Show"
                                                                Command="{Binding #Root.DataContext.SelectViewerFrameCommand}"
                                                                CommandParameter="{Binding FrameIndex}"
                                                                VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Paint">
                            <StackPanel Spacing="12">
                        <TextBlock Text="Paint shortcuts: M select  |  A lasso  |  G move  |  B brush  |  E erase  |  I dropper  |  F fill  |  L line  |  R rectangle  |  O ellipse  |  H mirror horizontal  |  V mirror vertical  |  Alt+Arrows move selection  |  Ctrl+C copy  |  Ctrl+V paste  |  Ctrl+Shift+H flip selection H  |  Ctrl+Shift+V flip selection V  |  Delete clear selection"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="10">
                            <TextBlock Text="{Binding CoreLoopSummary}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <Button Grid.Column="1"
                                    Content="Save + Replay"
                                    Command="{Binding SaveAndReturnToAnimateCommand}" />
                            <Button Grid.Column="2"
                                    Content="Back To Animate"
                                    Command="{Binding OpenAnimateWorkspaceCommand}" />
                        </Grid>
                        <Border Background="{DynamicResource AccentAuditBrush}"
                                CornerRadius="12"
                                Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding PaintStepSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding CurrentFrameReviewSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding StudioAiHandoffSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                <TextBlock Text="{Binding StudioCandidateHandoffSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <ComboBox ItemsSource="{Binding FrameReviewStatusOptions}"
                                          SelectedItem="{Binding SelectedFrameReviewStatus}"
                                          MinWidth="180"
                                          MaxWidth="260" />
                                <TextBox Text="{Binding SelectedFrameReviewNote}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="72"
                                         Watermark="Describe what needs work on this frame..." />
                                <TextBox Text="{Binding SelectedFrameIssueTagsText}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="52"
                                         Watermark="off_model, broken_outline, placeholder" />
                                <TextBlock Text="{Binding FrameReviewSaveMessage}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Stage Live Canvas"
                                            Command="{Binding StageEditorCanvasCandidateCommand}" />
                                    <Button Content="Create Request From Frame"
                                            Command="{Binding CreateRequestFromCurrentFrameCommand}" />
                                    <Button Content="Queue Selected Request"
                                            Command="{Binding QueueSelectedRequestForAutomationCommand}" />
                                    <Button Content="Save Frame Review"
                                            Command="{Binding SaveCurrentFrameReviewCommand}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Approve Frame"
                                            Command="{Binding MarkCurrentFrameApprovedCommand}" />
                                    <Button Content="Needs Review"
                                            Command="{Binding MarkCurrentFrameNeedsReviewCommand}" />
                                    <Button Content="To Repair"
                                            Command="{Binding MarkCurrentFrameToBeRepairedCommand}" />
                                    <Button Content="Template Only"
                                            Command="{Binding MarkCurrentFrameTemplateOnlyCommand}" />
                                </StackPanel>
                                </StackPanel>
                            </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Live Motion Monitor"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Keep the current animation moving beside your edit flow so you can judge timing and silhouette without leaving Paint."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Button Content="Play"
                                                Command="{Binding PlayPreviewCommand}" />
                                        <Button Content="Pause"
                                                Command="{Binding PausePreviewCommand}" />
                                        <Button Content="Use Live As Edit Target"
                                                Command="{Binding UsePlaybackFrameAsEditTargetCommand}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding LivePlaybackSummary}"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LivePlaybackActionSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="14">
                                    <StackPanel Spacing="8">
                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="Authored Playback"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <Grid Width="192"
                                              Height="192"
                                              HorizontalAlignment="Center">
                                            <Image Source="{Binding PlaybackFrameBitmap}"
                                                   Width="192"
                                                   Height="192"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasPlaybackFrameBitmap}" />
                                            <TextBlock Text="No authored playback frame"
                                                       IsVisible="{Binding IsPlaybackFrameBitmapMissing}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{Binding PlaybackModeSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Spacing="8">
                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="Runtime Playback"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <Grid Width="192"
                                              Height="192"
                                              HorizontalAlignment="Center">
                                            <Image Source="{Binding RuntimePlaybackFrameBitmap}"
                                                   Width="192"
                                                   Height="192"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasRuntimePlaybackFrameBitmap}" />
                                            <TextBlock Text="No runtime playback frame"
                                                       IsVisible="{Binding IsRuntimePlaybackFrameBitmapMissing}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{Binding RuntimePlaybackSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Frame Navigation"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Step through the current sequence, pick a neighboring frame, and use frame helpers without leaving Paint."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource AccentPillBrush}"
                                            CornerRadius="999"
                                            Padding="10,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ViewerSelectionSummary}"
                                                   FontWeight="Bold" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding PlaybackModeSummary}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,*,*,*"
                                      ColumnSpacing="8">
                                    <Button Content="Prev Frame"
                                            Command="{Binding StepPreviousFrameCommand}" />
                                    <Button Grid.Column="1"
                                            Content="Next Frame"
                                            Command="{Binding StepNextFrameCommand}" />
                                    <Button Grid.Column="2"
                                            Content="Restart"
                                            Command="{Binding RestartPreviewCommand}" />
                                    <Button Grid.Column="3"
                                            Content="Edit Current"
                                            Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="8">
                                    <Button Content="Edit Prev In Paint"
                                            Command="{Binding EditPreviousFrameCommand}" />
                                    <Button Grid.Column="1"
                                            Content="Edit Next In Paint"
                                            Command="{Binding EditNextFrameCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*"
                                      ColumnSpacing="8">
                                    <Button Content="Use Prev -&gt; Current"
                                            Command="{Binding CopyPreviousFrameIntoCurrentCommand}" />
                                    <Button Grid.Column="1"
                                            Content="Duplicate Current -&gt; Next"
                                            Command="{Binding DuplicateCurrentFrameToNextCommand}" />
                                    <Button Grid.Column="2"
                                            Content="Swap Current &lt;-&gt; Prev"
                                            Command="{Binding SwapCurrentFrameWithPreviousCommand}" />
                                </Grid>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding ViewerFrames}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ViewerFrameItemViewModel">
                                                    <Border Width="118"
                                                            Margin="0,0,10,0"
                                                            Padding="8"
                                                            Background="{DynamicResource SurfaceAltBrush}"
                                                            BorderBrush="{Binding FrameBorderBrush}"
                                                            BorderThickness="{Binding FrameBorderThickness}"
                                                            CornerRadius="10">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="{Binding FrameId}"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center" />
                                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Width="88"
                                                                    Height="88"
                                                                    HorizontalAlignment="Center">
                                                                <Grid>
                                                                    <Image Source="{Binding ThumbnailBitmap}"
                                                                           Stretch="Uniform"
                                                                           IsVisible="{Binding HasThumbnailBitmap}" />
                                                                    <TextBlock Text="{Binding ThumbnailLabel}"
                                                                               IsVisible="{Binding IsThumbnailMissing}"
                                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               TextAlignment="Center"
                                                                               FontSize="10" />
                                                                </Grid>
                                                            </Border>
                                                            <TextBlock Text="{Binding Marker}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       HorizontalAlignment="Center" />
                                                            <Button Content="Show"
                                                                    Command="{Binding #Root.DataContext.SelectViewerFrameCommand}"
                                                                    CommandParameter="{Binding FrameIndex}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Neighbor Frame References"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="Keep the surrounding authored frames visible while you polish spacing, silhouette, and timing."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="14">
                                    <StackPanel Spacing="8">
                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="Previous Frame"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <Grid Width="176"
                                              Height="176"
                                              HorizontalAlignment="Center">
                                            <Image Source="{Binding PreviousFrameReferenceBitmap}"
                                                   Width="176"
                                                   Height="176"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasPreviousFrameReferenceBitmap}" />
                                            <TextBlock Text="No previous frame"
                                                       IsVisible="{Binding IsPreviousFrameReferenceBitmapMissing}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{Binding PreviousFrameReferenceSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Spacing="8">
                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="Next Frame"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <Grid Width="176"
                                              Height="176"
                                              HorizontalAlignment="Center">
                                            <Image Source="{Binding NextFrameReferenceBitmap}"
                                                   Width="176"
                                                   Height="176"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding HasNextFrameReferenceBitmap}" />
                                            <TextBlock Text="No next frame"
                                                       IsVisible="{Binding IsNextFrameReferenceBitmapMissing}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{Binding NextFrameReferenceSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Paint and Edit"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Load the current authored frame or runtime template, make visible edits in-app, save, then replay the animation to judge the change."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Button Content="Load Current Frame"
                                                Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                                        <Button Content="Load Runtime Template"
                                                Command="{Binding LoadRuntimeFrameIntoEditorCommand}" />
                                        <Button Content="Prev Ref Layer"
                                                Command="{Binding AddPreviousFrameReferenceLayerCommand}" />
                                        <Button Content="Next Ref Layer"
                                                Command="{Binding AddNextFrameReferenceLayerCommand}" />
                                        <Button Content="Clear Frame"
                                                Command="{Binding ClearEditorFrameCommand}" />
                                        <Button Content="Undo"
                                                Command="{Binding UndoEditorEditCommand}" />
                                        <Button Content="Redo"
                                                Command="{Binding RedoEditorEditCommand}" />
                                        <Button Content="Revert"
                                                Command="{Binding RevertEditedFrameCommand}" />
                                        <Button Content="Capture For AI Review"
                                                Command="{Binding CaptureEditorReviewBundleCommand}" />
                                        <Button Content="Save Frame"
                                                Command="{Binding SaveEditedFrameCommand}" />
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="380,1.1*,0.9*"
                                      ColumnSpacing="14">
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="{Binding SelectedEditorColorSummary}"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Tool"
                                                               FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding EditorToolOptions}"
                                                              SelectedItem="{Binding SelectedEditorTool}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="6">
                                                    <TextBlock Text="Brush"
                                                               FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding EditorBrushSizeOptions}"
                                                              SelectedItem="{Binding SelectedEditorBrushSize}"
                                                              MinWidth="70" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Zoom"
                                                               FontWeight="Bold" />
                                                    <ComboBox ItemsSource="{Binding EditorZoomOptions}"
                                                              SelectedItem="{Binding SelectedEditorZoom}"
                                                              MinWidth="90" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="6">
                                                    <TextBlock Text="Color"
                                                               FontWeight="Bold" />
                                                    <TextBox Text="{Binding SelectedEditorColorHex}"
                                                             MinWidth="110" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12">
                                                <CheckBox Content="Mirror Horizontal"
                                                          IsChecked="{Binding EditorMirrorHorizontal}" />
                                                <CheckBox Content="Mirror Vertical"
                                                          IsChecked="{Binding EditorMirrorVertical}" />
                                                <CheckBox Content="Fill Shapes"
                                                          IsChecked="{Binding EditorFillShapes}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding EditorCanvasSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding EditorSelectionSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorMirrorSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorShapeModeSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorTemplateSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorHistorySummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding EditorToolHint}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorCaptureSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorCapturePathSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding LastEditorCaptureSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorLoadedFramePath}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorStatusMessage}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />

                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12">
                                                <CheckBox Content="Auto Capture On Stroke"
                                                          IsChecked="{Binding AutoCaptureOnStroke}" />
                                                <CheckBox Content="Auto Capture On Save"
                                                          IsChecked="{Binding AutoCaptureOnSave}" />
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Color Controls"
                                                           FontWeight="Bold" />
                                                <Border Width="64"
                                                        Height="64"
                                                        Background="{Binding EditorSelectedColorBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="8" />
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="R"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="255"
                                                            Value="{Binding EditorRed}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorRed}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="G"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="255"
                                                            Value="{Binding EditorGreen}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorGreen}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="B"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="255"
                                                            Value="{Binding EditorBlue}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorBlue}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="A"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="255"
                                                            Value="{Binding EditorAlpha}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorAlpha}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <TextBlock Text="{Binding EditorHsvSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="H"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="359"
                                                            Value="{Binding EditorHue}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorHue}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="S"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            Value="{Binding EditorSaturation}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorSaturation}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="V"
                                                               VerticalAlignment="Center" />
                                                    <Slider Grid.Column="1"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            Value="{Binding EditorValue}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding EditorValue}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Palette"
                                                           FontWeight="Bold" />
                                                <ItemsControl ItemsSource="{Binding EditorPalette}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:EditorPaletteColorItemViewModel">
                                                            <StackPanel Spacing="4"
                                                                        Margin="0,0,8,8">
                                                                <Button Width="30"
                                                                        Height="30"
                                                                        Background="{Binding Brush}"
                                                                        BorderBrush="#4F463A"
                                                                        BorderThickness="1"
                                                                        Command="{Binding #Root.DataContext.UseEditorPaletteColorCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                                <TextBlock Text="{Binding SelectionLabel}"
                                                                           FontSize="10"
                                                                           HorizontalAlignment="Center" />
                                                                <TextBlock Text="{Binding HexColor}"
                                                                           FontSize="10"
                                                                           HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Saved Swatches"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding SavedPaletteSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Save Current"
                                                            Command="{Binding SaveCurrentColorToPaletteCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Remove Current"
                                                            Command="{Binding RemoveCurrentColorFromPaletteCommand}" />
                                                </Grid>
                                                <Button Content="Clear Saved Swatches"
                                                        Command="{Binding ClearSavedPaletteCommand}" />
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Extract Frame Palette"
                                                            Command="{Binding ExtractCurrentFramePaletteCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Save As Project Palette"
                                                            Command="{Binding SaveSavedSwatchesAsProjectPaletteCommand}" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding SavedEditorPalette}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:EditorPaletteColorItemViewModel">
                                                            <StackPanel Spacing="4"
                                                                        Margin="0,0,8,8">
                                                                <Button Width="30"
                                                                        Height="30"
                                                                        Background="{Binding Brush}"
                                                                        BorderBrush="#4F463A"
                                                                        BorderThickness="1"
                                                                        Command="{Binding #Root.DataContext.UseEditorPaletteColorCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                                <TextBlock Text="{Binding SelectionLabel}"
                                                                           FontSize="10"
                                                                           HorizontalAlignment="Center" />
                                                                <TextBlock Text="{Binding HexColor}"
                                                                           FontSize="10"
                                                                           HorizontalAlignment="Center" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10">
                                                    <StackPanel Spacing="8">
                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="8">
                                                            <TextBlock Text="Project Palettes"
                                                                       FontWeight="Bold" />
                                                            <Border Grid.Column="1"
                                                                    Background="{DynamicResource AccentPillBrush}"
                                                                    CornerRadius="999"
                                                                    Padding="10,4">
                                                                <TextBlock Text="{Binding ProjectPaletteSummary}" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Text="{Binding SelectedProjectPaletteSummary}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding ProjectPaletteMessage}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8">
                                                            <Button Content="Load Into Swatches"
                                                                    Command="{Binding ApplySelectedProjectPaletteCommand}" />
                                                            <Button Content="Delete Palette"
                                                                    Command="{Binding DeleteSelectedProjectPaletteCommand}" />
                                                        </StackPanel>
                                                        <ListBox ItemsSource="{Binding ProjectPalettes}"
                                                                 SelectedItem="{Binding SelectedProjectPaletteItem}"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 MaxHeight="160">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:ProjectPaletteItemViewModel">
                                                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            Padding="10"
                                                                            Margin="0,0,0,8">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                       FontWeight="Bold"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding ColorSummary}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding PreviewSummary}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding UpdatedLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Layers"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding EditorLayerSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding ActiveEditorLayerSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding EditorLayerWorkflowHint}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                                <Grid ColumnDefinitions="*,*,*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Add Layer"
                                                            Command="{Binding AddBlankEditorLayerCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Duplicate"
                                                            Command="{Binding DuplicateActiveEditorLayerCommand}" />
                                                    <Button Grid.Column="2"
                                                            Content="Lift Selection"
                                                            Command="{Binding LiftSelectionToNewLayerCommand}" />
                                                    <Button Grid.Column="3"
                                                            Content="Remove"
                                                            Command="{Binding RemoveActiveEditorLayerCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*,*,*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Lock Others"
                                                            Command="{Binding LockAllButActiveEditorLayerCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Unlock All"
                                                            Command="{Binding UnlockAllEditorLayersCommand}" />
                                                    <Button Grid.Column="2"
                                                            Content="Solo Active"
                                                            Command="{Binding SoloActiveEditorLayerCommand}" />
                                                    <Button Grid.Column="3"
                                                            Content="Show All"
                                                            Command="{Binding ShowAllEditorLayersCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*,*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Runtime Template"
                                                            Command="{Binding AddRuntimeTemplateLayerCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Merge Up"
                                                            Command="{Binding MergeActiveEditorLayerUpCommand}" />
                                                    <Button Grid.Column="2"
                                                            Content="Merge Down"
                                                            Command="{Binding MergeActiveLayerDownCommand}" />
                                                    <Button Grid.Column="3"
                                                            Content="Flatten Visible"
                                                            Command="{Binding FlattenVisibleLayersCommand}" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding EditorLayers}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:EditorLayerItemViewModel">
                                                            <Border Padding="10"
                                                                    Margin="0,0,0,8"
                                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8">
                                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
                                                                      ColumnSpacing="8">
                                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6"
                                                                            Width="58"
                                                                            Height="58"
                                                                            Padding="4"
                                                                            VerticalAlignment="Top">
                                                                        <Grid>
                                                                            <Image Source="{Binding ThumbnailBitmap}"
                                                                                   Stretch="Uniform"
                                                                                   IsVisible="{Binding HasThumbnail}" />
                                                                            <TextBlock Text="No art"
                                                                                       IsVisible="{Binding IsThumbnailMissing}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       FontSize="10" />
                                                                        </Grid>
                                                                    </Border>
                                                                    <StackPanel Spacing="6">
                                                                        <TextBox Text="{Binding Name}"
                                                                                 Watermark="Layer name" />
                                                                        <Border Background="{DynamicResource AccentPillBrush}"
                                                                                CornerRadius="999"
                                                                                Padding="8,3"
                                                                                HorizontalAlignment="Left">
                                                                            <TextBlock Text="{Binding RoleLabel}"
                                                                                       FontSize="11"
                                                                                       FontWeight="Bold" />
                                                                        </Border>
                                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   FontSize="11" />
                                                                        <TextBlock Text="{Binding PixelCoverageLabel}"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   FontSize="11" />
                                                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                                                              ColumnSpacing="8">
                                                                            <TextBlock Text="Opacity"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <Slider Grid.Column="1"
                                                                                    Minimum="0"
                                                                                    Maximum="100"
                                                                                    Value="{Binding OpacityPercent}" />
                                                                            <TextBlock Grid.Column="2"
                                                                                       Text="{Binding OpacityPercent}"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                        </Grid>
                                                                    </StackPanel>
                                                                    <Button Grid.Column="2"
                                                                            Content="{Binding VisibilityActionLabel}"
                                                                            Command="{Binding #Root.DataContext.ToggleEditorLayerVisibilityCommand}"
                                                                            CommandParameter="{Binding .}" />
                                                                    <Button Grid.Column="3"
                                                                            Content="{Binding SelectionActionLabel}"
                                                                            Command="{Binding #Root.DataContext.SelectEditorLayerCommand}"
                                                                            CommandParameter="{Binding .}" />
                                                                    <Button Grid.Column="4"
                                                                            Content="{Binding LockActionLabel}"
                                                                            Command="{Binding #Root.DataContext.ToggleEditorLayerLockCommand}"
                                                                            CommandParameter="{Binding .}" />
                                                                    <Button Grid.Column="5"
                                                                            Content="{Binding MoveUpActionLabel}"
                                                                            Command="{Binding #Root.DataContext.MoveEditorLayerUpCommand}"
                                                                            CommandParameter="{Binding .}" />
                                                                    <Button Grid.Column="6"
                                                                            Content="{Binding MoveDownActionLabel}"
                                                                            Command="{Binding #Root.DataContext.MoveEditorLayerDownCommand}"
                                                                            CommandParameter="{Binding .}" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Selection"
                                                           FontWeight="Bold" />
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Select All"
                                                            Command="{Binding SelectAllEditorPixelsCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Clear"
                                                            Command="{Binding ClearEditorSelectionCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Copy"
                                                            Command="{Binding CopyEditorSelectionCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Paste"
                                                            Command="{Binding PasteEditorSelectionCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Flip H"
                                                            Command="{Binding FlipSelectionHorizontalCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Flip V"
                                                            Command="{Binding FlipSelectionVerticalCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Rotate L"
                                                            Command="{Binding RotateSelectionLeftCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Rotate R"
                                                            Command="{Binding RotateSelectionRightCommand}" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <Button Content="Scale 2x"
                                                            Command="{Binding ScaleSelectionUpCommand}" />
                                                    <Button Grid.Column="1"
                                                            Content="Scale 1/2"
                                                            Command="{Binding ScaleSelectionDownCommand}" />
                                                </Grid>
                                                <Button Content="Delete Selected"
                                                        Command="{Binding DeleteEditorSelectionCommand}" />
                                                <Grid ColumnDefinitions="Auto,Auto,Auto"
                                                      ColumnSpacing="8"
                                                      HorizontalAlignment="Left">
                                                    <Button Content="Up"
                                                            Command="{Binding MoveSelectionUpCommand}" />
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                Spacing="8">
                                                        <Button Content="Left"
                                                                Command="{Binding MoveSelectionLeftCommand}" />
                                                        <Button Content="Right"
                                                                Command="{Binding MoveSelectionRightCommand}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Content="Down"
                                                            Command="{Binding MoveSelectionDownCommand}" />
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14">
                                        <Grid>
                                            <Border IsVisible="{Binding IsEditorFrameMissing}"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="20">
                                                <StackPanel Spacing="12"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="Editor Not Ready"
                                                               FontSize="18"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding EditorEmptyStateSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8">
                                                        <Button Content="Load Current Frame"
                                                                Command="{Binding LoadCurrentFrameIntoEditorCommand}" />
                                                        <Button Content="Create Blank Frame"
                                                                Command="{Binding CreateBlankCurrentFrameCommand}" />
                                                        <Button Content="Load Runtime Template"
                                                                Command="{Binding LoadRuntimeFrameIntoEditorCommand}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <ScrollViewer IsVisible="{Binding IsEditorFrameLoaded}"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto">
                                                <Border Width="{Binding EditorCanvasWidth}">
                                                    <ItemsControl ItemsSource="{Binding EditorPixels}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:EditorPixelItemViewModel">
                                                                <Border Width="{Binding #Root.DataContext.EditorPixelSize}"
                                                                        Height="{Binding #Root.DataContext.EditorPixelSize}"
                                                                        Margin="0"
                                                                        Padding="0"
                                                                        Background="{Binding Brush}"
                                                                        BorderBrush="{Binding BorderBrush}"
                                                                        BorderThickness="{Binding BorderThickness}"
                                                                        Tag="{Binding .}"
                                                                        ToolTip.Tip="{Binding Label}"
                                                                        PointerPressed="OnEditorPixelPointerPressed"
                                                                        PointerEntered="OnEditorPixelPointerEntered"
                                                                        PointerReleased="OnEditorPixelPointerReleased" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Live Reference Monitor"
                                                       FontSize="16"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding PaintMonitorSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding EditorComparisonSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="Selected Authored Frame"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                    <Grid Width="192"
                                                          Height="192"
                                                          HorizontalAlignment="Center">
                                                        <Image Source="{Binding CurrentFrameBitmap}"
                                                               Width="192"
                                                               Height="192"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding HasCurrentFrameBitmap}" />
                                                        <TextBlock Text="No authored frame"
                                                                   IsVisible="{Binding IsCurrentFrameBitmapMissing}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding ViewerFrameSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="Runtime / Base Reference"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                    <Grid Width="192"
                                                          Height="192"
                                                          HorizontalAlignment="Center">
                                                        <Image Source="{Binding RuntimeFrameBitmap}"
                                                               Width="192"
                                                               Height="192"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding HasRuntimeFrameBitmap}" />
                                                        <TextBlock Text="No runtime frame"
                                                                   IsVisible="{Binding IsRuntimeFrameBitmapMissing}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding RuntimeViewerFrameSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="Loaded Baseline"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                    <Grid Width="192"
                                                          Height="192"
                                                          HorizontalAlignment="Center">
                                                        <Image Source="{Binding EditorBaselineBitmap}"
                                                               Width="192"
                                                               Height="192"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding HasEditorBaselineBitmap}" />
                                                        <TextBlock Text="No baseline yet"
                                                                   IsVisible="{Binding IsEditorBaselineBitmapMissing}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="The baseline is the frame as it looked when it was loaded or last saved."
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="Diff View"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                    <Grid Width="192"
                                                          Height="192"
                                                          HorizontalAlignment="Center">
                                                        <Image Source="{Binding EditorDiffBitmap}"
                                                               Width="192"
                                                               Height="192"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding HasEditorDiffBitmap}" />
                                                        <TextBlock Text="No diff yet"
                                                                   IsVisible="{Binding IsEditorDiffBitmapMissing}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding EditorComparisonSummary}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource AccentAuditBrush}"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="What Stays Visible"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="The live editable canvas stays open beside the selected authored frame and runtime reference so edits can be watched and judged in context."
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding EditorStatusMessage}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="Frame History"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text="{Binding FrameHistorySummary}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Open Folder"
                                                                Command="{Binding OpenFrameHistoryFolderCommand}" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding FrameHistoryDirectoryDisplay}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding FrameHistoryMessage}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <ItemsControl ItemsSource="{Binding FrameHistoryItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:FrameHistoryItemViewModel">
                                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="8"
                                                                        Margin="0,0,0,6">
                                                                    <Grid ColumnDefinitions="*,Auto"
                                                                          ColumnSpacing="8">
                                                                        <StackPanel Spacing="2">
                                                                            <TextBlock Text="{Binding Label}"
                                                                                       FontWeight="Bold" />
                                                                            <TextBlock Text="{Binding TimestampLabel}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                            <TextBlock Text="{Binding FileName}"
                                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                       TextWrapping="Wrap" />
                                                                        </StackPanel>
                                                                        <Button Grid.Column="1"
                                                                                Content="Restore"
                                                                                Command="{Binding DataContext.RestoreFrameHistoryVersionCommand, ElementName=Root}"
                                                                                CommandParameter="{Binding .}" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    </Border>
                    </TabItem>

                    <TabItem Header="Planning">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18"
                            Margin="0,6,0,0">
                        <Grid ColumnDefinitions="1.3*,*"
                              ColumnSpacing="16">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Project Discovery and Planning"
                                               FontSize="16"
                                               FontWeight="Bold" />
                                    <TextBlock Text="{Binding PlanningProjectModeSummary}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Discovery Snapshot"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding PlanningDiscoverySummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PlanningAdoptionSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PlanningGapSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PlanningStarterHint}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Button Content="Adopt Discovered Assets"
                                                    Command="{Binding AdoptDiscoveredAssetsIntoPlanningCommand}" />
                                            <Button Content="Reset To Project Contract"
                                                    Command="{Binding ResetPlanningBlueprintToProjectCommand}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding PlanningDiscoveryAdoptionMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Adoption Diagnostics"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="This compares the plan you are shaping with the assets and axes the linked project already exposes."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding PlanningDiagnostics}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PlanningDiagnosticItemViewModel">
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Project Validation"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding ValidationReportSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                <Button Content="Run Validation"
                                                        Command="{Binding RunProjectValidationCommand}" />
                                                <Button Content="Open Selected"
                                                        Command="{Binding OpenSelectedValidationReportCommand}" />
                                                <Button Content="Open Folder"
                                                        Command="{Binding OpenValidationReportFolderCommand}" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding SelectedValidationReportSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ProjectValidationMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <ListBox ItemsSource="{Binding ValidationReports}"
                                                 SelectedItem="{Binding SelectedValidationReportItem}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MinHeight="120"
                                                 MaxHeight="220">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ValidationReportItemViewModel">
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text="{Binding Summary}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding UpdatedLabel}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Release And Portability"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Package the current project workflow for reuse and create a blank validation sandbox to prove portability outside the linked project."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Button Content="Export Project Kit"
                                                    Command="{Binding ExportProjectKitCommand}" />
                                            <Button Content="Open Kit Folder"
                                                    Command="{Binding OpenProjectKitFolderCommand}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding ProjectKitMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Button Content="Create Validation Sandbox"
                                                    Command="{Binding CreateValidationSandboxCommand}" />
                                            <Button Content="Open Sandbox Folder"
                                                    Command="{Binding OpenValidationSandboxFolderCommand}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding ValidationSandboxMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Planned Sequence Adoption"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding PlanningAdoptionEntrySummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Each row below compares one planned sequence target against the PNGs already discovered in the linked authored tree."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <ScrollViewer MaxHeight="280">
                                            <ItemsControl ItemsSource="{Binding PlanningAdoptionEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:PlanningAdoptionEntryItemViewModel">
                                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="10"
                                                                Margin="0,0,0,8">
                                                            <StackPanel Spacing="4">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      ColumnSpacing="8">
                                                                    <TextBlock Text="{Binding VariantSummary}"
                                                                               FontWeight="Bold"
                                                                               TextWrapping="Wrap" />
                                                                    <Border Grid.Column="1"
                                                                            Background="{DynamicResource AccentPillBrush}"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding StatusLabel}" />
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Text="{Binding SequenceSummary}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                <TextBlock Text="{Binding CoverageLabel}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                                <TextBlock Text="{Binding ExtraLabel}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Unmapped Discovered Assets"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding PlanningUnmappedEntrySummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="These authored PNGs were discovered on disk but are not covered by the current planning checklist."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <Button Content="Adopt Selected"
                                                    Command="{Binding AdoptSelectedPlanningUnmappedEntryCommand}" />
                                            <Button Content="Open Asset"
                                                    Command="{Binding OpenSelectedPlanningUnmappedAssetCommand}" />
                                        </StackPanel>
                                        <ScrollViewer MaxHeight="240">
                                            <ListBox ItemsSource="{Binding PlanningUnmappedEntries}"
                                                     SelectedItem="{Binding SelectedPlanningUnmappedEntryItem}"
                                                     BorderThickness="0"
                                                     Background="Transparent">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:PlanningUnmappedEntryItemViewModel">
                                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                                BorderBrush="{DynamicResource BorderBrushDark}"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="10"
                                                                Margin="0,0,0,8">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="Bold"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding SequenceSummary}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding RelativePath}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Reason}"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Project Templates"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding PlanningTemplateSummary}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                <Button Content="Save Template"
                                                        Command="{Binding SavePlanningTemplateCommand}" />
                                                <Button Content="Load Selected"
                                                        Command="{Binding LoadSelectedPlanningTemplateCommand}" />
                                                <Button Content="Delete Selected"
                                                        Command="{Binding DeleteSelectedPlanningTemplateCommand}" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding PlanningTemplateMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <ListBox ItemsSource="{Binding PlanningTemplates}"
                                                 SelectedItem="{Binding SelectedPlanningTemplateItem}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MinHeight="120"
                                                 MaxHeight="220">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PlanningTemplateItemViewModel">
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text="{Binding UpdatedLabel}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding AxisSummary}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding BlueprintPreview}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="12">
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Planning Axes"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding PlanningAxisSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Checklist Target"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="{Binding PlanningChecklistSummary}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,Auto,Auto"
                                      ColumnSpacing="10">
                                    <Button Content="Use Discovered Blueprint"
                                            Command="{Binding ResetPlanningBlueprintToProjectCommand}" />
                                    <Button Grid.Column="1"
                                            Content="Start Blank"
                                            Command="{Binding ClearPlanningBlueprintCommand}" />
                                    <Button Grid.Column="2"
                                            Content="Adopt From Assets"
                                            Command="{Binding AdoptDiscoveredAssetsIntoPlanningCommand}" />
                                </Grid>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Starter Project Profile"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding PlanningProjectExportSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12"
                                              RowDefinitions="Auto,Auto,Auto,Auto">
                                            <TextBlock Text="Project Id"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding PlanningProjectId}"
                                                     Watermark="my-sprite-project" />
                                            <TextBlock Grid.Row="1"
                                                       Text="Display Name"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding PlanningDisplayName}"
                                                     Watermark="My Sprite Project" />
                                            <TextBlock Grid.Row="2"
                                                       Text="Root Path"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding PlanningRootPath}"
                                                     Watermark="C:\path\to\project" />
                                            <TextBlock Grid.Row="3"
                                                       Text="Export Path"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Text="{Binding PlanningExportPath}"
                                                     Watermark="C:\path\to\project\my-sprite-project.project.json" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">
                                            <Button Content="Create Starter Workspace"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding CreatePlanningStarterWorkspaceCommand}" />
                                            <Button Content="Create Asset Skeleton"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding CreatePlanningAssetSkeletonCommand}" />
                                            <Button Content="Generate Blank Planned Frames"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding GeneratePlanningBlankFramesCommand}" />
                                            <Button Content="Export Starter Profile"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding ExportPlanningProjectProfileCommand}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding PlanningWorkspaceMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PlanningSkeletonMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PlanningFrameGenerationMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding PlanningExportMessage}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="Project Axes"
                                                   FontWeight="Bold" />
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12"
                                              RowDefinitions="Auto,Auto,Auto,Auto">
                                            <TextBlock Text="Species"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding PlanningSpeciesText}"
                                                     Watermark="crow, deer, fox"
                                                     TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1"
                                                       Text="Ages"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="1"
                                                     Grid.Column="1"
                                                     Text="{Binding PlanningAgeText}"
                                                     Watermark="adult, teen, baby"
                                                     TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="2"
                                                       Text="Genders"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="2"
                                                     Grid.Column="1"
                                                     Text="{Binding PlanningGenderText}"
                                                     Watermark="female, male"
                                                     TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="3"
                                                       Text="Colors"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Text="{Binding PlanningColorText}"
                                                     Watermark="red, orange, yellow, blue"
                                                     TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Animation Family Blueprint"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="Use one family per line, for example: locomotion: idle x4, walk x6"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBox Text="{Binding PlanningFamilyBlueprintText}"
                                                 AcceptsReturn="True"
                                                 MinHeight="160"
                                                 TextWrapping="Wrap"
                                                 VerticalContentAlignment="Top" />
                                        <TextBlock Text="{Binding PlanningAnimationSummary}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="14">
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Checklist Preview"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="This becomes the visible art plan for manual drawing, AI requests, or automated loops."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding PlanningChecklist}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PlanningChecklistItemViewModel">
                                                    <Border Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrushDark}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="10"
                                                            Margin="0,0,0,8">
                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="{Binding Family}"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text="{Binding SequenceSummary}"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                            <WrapPanel ItemWidth="120">
                                                                <Border Background="{DynamicResource AccentPillBrush}"
                                                                        CornerRadius="999"
                                                                        Padding="8,4"
                                                                        Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding SequenceCountLabel}" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AccentPillBrush}"
                                                                        CornerRadius="999"
                                                                        Padding="8,4"
                                                                        Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding FramesPerBaseRowLabel}" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AccentPillBrush}"
                                                                        CornerRadius="999"
                                                                        Padding="8,4"
                                                                        Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding BaseRowsLabel}" />
                                                                </Border>
                                                                <Border Background="{DynamicResource AccentPillBrush}"
                                                                        CornerRadius="999"
                                                                        Padding="8,4"
                                                                        Margin="0,0,8,6">
                                                                    <TextBlock Text="{Binding ColorVariantsLabel}" />
                                                                </Border>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Discovered Coverage Snapshot"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="If the linked project already has assets, you can compare the current sprite contract with the plan you are shaping above."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <Grid ColumnDefinitions="2*,Auto,Auto,Auto"
                                              Margin="0,0,0,8">
                                            <TextBlock Text="Species"
                                                       FontWeight="Bold" />
                                            <TextBlock Grid.Column="1"
                                                       Text="Locomotion"
                                                       FontWeight="Bold"
                                                       Margin="16,0,0,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="Care"
                                                       FontWeight="Bold"
                                                       Margin="16,0,0,0" />
                                            <TextBlock Grid.Column="3"
                                                       Text="Expression"
                                                       FontWeight="Bold"
                                                       Margin="16,0,0,0" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding SpeciesCoverage}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SpeciesCoverageItemViewModel">
                                                    <Grid ColumnDefinitions="2*,Auto,Auto,Auto"
                                                          Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding Species}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Locomotion}"
                                                                   Margin="16,0,0,0" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Care}"
                                                                   Margin="16,0,0,0" />
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding Expression}"
                                                                   Margin="16,0,0,0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Window>
